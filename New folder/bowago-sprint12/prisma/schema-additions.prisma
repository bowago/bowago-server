// Sprint 2 — B2B Contract Rate Cards
model ContractRate {
  id                     String      @id @default(uuid())
  userId                 String      @unique
  label                  String?
  serviceType            ServiceType?
  discountPercent        Float?
  fixedPricePerKgByZone  Json?
  isActive               Boolean     @default(true)
  validFrom              DateTime?
  validUntil             DateTime?
  notes                  String?
  createdBy              String?
  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@map("contract_rates")
}

// Sprint 2 — Promo Codes
model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  description     String?
  discountPercent Float?
  flatDiscount    Float?
  minOrderAmount  Float?
  maxUses         Int?
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  serviceType     ServiceType?
  createdBy       String?
  redemptions     PromoRedemption[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("promo_codes")
}

model PromoRedemption {
  id              String    @id @default(uuid())
  promoCodeId     String
  userId          String
  shipmentId      String?
  discountApplied Float
  promoCode       PromoCode @relation(fields: [promoCodeId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([promoCodeId, userId, shipmentId])
  @@map("promo_redemptions")
}

// Sprint 2 / Story 9.4 — Policy & T&C content
model PolicyContent {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  body      String
  isActive  Boolean  @default(true)
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("policy_content")
}

// Sprint 5 / Story 11.5 — Packaging guide
model PackagingGuide {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    String
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isDangerous Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("packaging_guides")
}
