generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum AdminSubRole {
  LOGISTICS_MANAGER
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum ShipmentStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
  RETURNED
  PENDING_ADMIN_REVIEW  // Sprint 5 — address change awaiting approval
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentChannel {
  CARD
  BANK_TRANSFER
  USSD
  MOBILE_MONEY
  QR
}

enum WeightUnit {
  KG
  TONS
  CARTONS
}

enum NotificationType {
  SHIPMENT_UPDATE
  PAYMENT
  PROMO
  SYSTEM
  DELAY_ALERT
  PRICE_ADJUSTMENT
}

enum ServiceType {
  EXPRESS
  STANDARD
  ECONOMY
}

enum SurchargeType {
  FUEL
  REMOTE_AREA
  VAT
  FRAGILE
  INSURANCE
  OVERSIZE
}

enum AddressChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketCategory {
  TRACKING
  PAYMENT
  PRICING_DISPUTE
  DAMAGED_GOODS
  DELIVERY_ISSUE
  ACCOUNT
  OTHER
}

enum FaqCategory {
  PRICING
  SHIPPING_RULES
  TRACKING
  PAYMENTS
  ACCOUNT
  PACKAGING
  CLAIMS
  OTHER
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  phone            String?       @unique
  firstName        String
  lastName         String
  avatar           String?
  avatarPublicId   String?
  role             UserRole      @default(CUSTOMER)
  adminSubRole     AdminSubRole?
  authProvider     AuthProvider  @default(EMAIL)
  googleId         String?       @unique
  appleId          String?       @unique
  passwordHash     String?
  isEmailVerified  Boolean       @default(false)
  isPhoneVerified  Boolean       @default(false)
  isActive         Boolean       @default(true)
  fcmToken         String?

  addresses           Address[]
  shipments           Shipment[]           @relation("CustomerShipments")
  managedShipments    Shipment[]           @relation("AssignedShipments")
  otpCodes            OtpCode[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  payments            Payment[]
  addressChangeReqs   AddressChangeRequest[]
  claims              Claim[]
  supportTickets      SupportTicket[]      @relation("TicketCustomer")
  assignedTickets     SupportTicket[]      @relation("TicketAgent")
  priceAuditLogs      PriceAuditLog[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("users")
}

model Address {
  id          String    @id @default(uuid())
  userId      String
  label       String?
  street      String
  city        String
  state       String
  lga         String?
  postalCode  String?
  country     String    @default("Nigeria")
  lat         Float?
  lng         Float?
  isDefault   Boolean   @default(false)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("addresses")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model OtpCode {
  id        String    @id @default(uuid())
  userId    String
  code      String
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@map("otp_codes")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  ipAddress  String?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@map("refresh_tokens")
}

// ─── PRICING PARAMETERS ──────────────────────────────────────────────────────

model City {
  id        String    @id @default(uuid())
  name      String    @unique
  region    String
  state     String

  fromZones ZoneMatrix[] @relation("FromCity")
  toZones   ZoneMatrix[] @relation("ToCity")
  fromKm    KmMatrix[]   @relation("FromCityKm")
  toKm      KmMatrix[]   @relation("ToCityKm")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("cities")
}

model BoxDimension {
  id              String    @id @default(uuid())
  categoryId      String    @unique
  displayName     String
  lengthCm        Float
  widthCm         Float
  heightCm        Float
  bestFor         String?
  weightKgLimit   Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("box_dimensions")
}

model ZoneMatrix {
  id          String    @id @default(uuid())
  fromCityId  String
  toCityId    String
  zone        Int

  fromCity    City      @relation("FromCity", fields: [fromCityId], references: [id])
  toCity      City      @relation("ToCity", fields: [toCityId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([fromCityId, toCityId])
  @@map("zone_matrix")
}

model KmMatrix {
  id          String    @id @default(uuid())
  fromCityId  String
  toCityId    String
  distanceKm  Float

  fromCity    City      @relation("FromCityKm", fields: [fromCityId], references: [id])
  toCity      City      @relation("ToCityKm", fields: [toCityId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([fromCityId, toCityId])
  @@map("km_matrix")
}

model PriceBand {
  id              String      @id @default(uuid())
  zone            Int
  serviceType     ServiceType @default(STANDARD)
  minKg           Float
  maxKg           Float?
  minTons         Float
  maxTons         Float?
  minCartons      Int
  maxCartons      Int?
  pricePerKg      Float?
  basePrice       Float?
  isActive        Boolean     @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("price_bands")
}

// Sprint 2: Surcharge Engine
model Surcharge {
  id          String        @id @default(uuid())
  type        SurchargeType
  label       String        // "Fuel Surcharge", "Remote Area Fee", "VAT"
  description String?       // Tooltip text explaining why it's charged
  ratePercent Float?        // e.g. 5.5 = 5.5%
  flatAmount  Float?        // Flat NGN amount
  isActive    Boolean       @default(true)
  appliesTo   String?       // "ALL" | "EXPRESS" | "STANDARD" | "ECONOMY"

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("surcharges")
}

// Sprint 8: Price version history / audit trail
model PriceAuditLog {
  id            String    @id @default(uuid())
  entityType    String    // "PriceBand" | "Surcharge" | "AppSettings"
  entityId      String
  action        String    // "CREATE" | "UPDATE" | "DELETE"
  previousValue Json?
  newValue      Json?
  changedBy     String
  reason        String?

  user          User      @relation(fields: [changedBy], references: [id])

  createdAt     DateTime  @default(now())

  @@map("price_audit_logs")
}

// ─── SHIPMENT ─────────────────────────────────────────────────────────────────

model Shipment {
  id               String         @id @default(uuid())
  trackingNumber   String         @unique
  customerId       String
  assignedToId     String?

  senderName       String
  senderPhone      String
  senderAddress    String
  senderCity       String
  senderState      String

  recipientName    String
  recipientPhone   String
  recipientAddress String
  recipientCity    String
  recipientState   String

  description      String?
  weight           Float
  weightUnit       WeightUnit      @default(KG)
  cartons          Int?
  boxDimensionId   String?
  customLength     Float?
  customWidth      Float?
  customHeight     Float?

  serviceType      ServiceType     @default(STANDARD)
  fromCityId       String?
  toCityId         String?
  zone             Int?
  distanceKm       Float?
  quotedPrice      Float
  finalPrice       Float?
  currency         String          @default("NGN")

  // Sprint 2: surcharge breakdown stored as JSON
  surchargeBreakdown Json?         // [{ label, amount, type }]

  status           ShipmentStatus  @default(PENDING)
  paymentStatus    PaymentStatus   @default(PENDING)

  // Sprint 3: Cut-off time logic
  cutoffWarning    Boolean         @default(false) // true if booked after 2pm same-day

  pickupDate       DateTime?
  estimatedDelivery DateTime?
  deliveredAt      DateTime?

  isFragile        Boolean         @default(false)
  requiresInsurance Boolean        @default(false)
  insuranceValue   Float?
  notes            String?

  customer         User            @relation("CustomerShipments", fields: [customerId], references: [id])
  assignedTo       User?           @relation("AssignedShipments", fields: [assignedToId], references: [id])
  trackingHistory  TrackingEvent[]
  documents        ShipmentDocument[]
  payments         Payment[]
  addressChangeReqs AddressChangeRequest[]
  claims           Claim[]
  priceAdjustments PriceAdjustment[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("shipments")
}

model TrackingEvent {
  id          String    @id @default(uuid())
  shipmentId  String
  status      ShipmentStatus
  location    String?
  description String
  lat         Float?
  lng         Float?
  updatedBy   String?
  proofUrl    String?

  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@map("tracking_events")
}

model ShipmentDocument {
  id           String   @id @default(uuid())
  shipmentId   String
  type         String   // WAYBILL | INVOICE | PROOF_OF_DELIVERY | OTHER
  url          String
  publicId     String
  uploadedBy   String?

  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@map("shipment_documents")
}

// Sprint 5: Address change request workflow
model AddressChangeRequest {
  id                String              @id @default(uuid())
  shipmentId        String
  userId            String
  newRecipientAddress String
  newRecipientCity    String
  newRecipientState   String
  reason            String?
  status            AddressChangeStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNote        String?

  shipment          Shipment            @relation(fields: [shipmentId], references: [id])
  user              User                @relation(fields: [userId], references: [id])

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("address_change_requests")
}

// Sprint 5 & 8: Post-booking price adjustment (weight discrepancy at hub)
model PriceAdjustment {
  id              String    @id @default(uuid())
  shipmentId      String
  originalPrice   Float
  adjustedPrice   Float
  difference      Float
  reason          String    // "Weight discrepancy: quoted 50kg, actual 65kg"
  actualWeightKg  Float?
  proofImageUrl   String?   // Photo of scale at warehouse
  isAcknowledged  Boolean   @default(false)
  acknowledgedAt  DateTime?
  isPaid          Boolean   @default(false)
  paymentRef      String?

  shipment        Shipment  @relation(fields: [shipmentId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("price_adjustments")
}

// Sprint 7: Insurance claims
model Claim {
  id              String      @id @default(uuid())
  shipmentId      String
  userId          String
  type            String      // "DAMAGE" | "LOSS" | "DELAY"
  description     String
  declaredValue   Float
  claimAmount     Float
  bankName        String?
  accountNumber   String?
  accountName     String?
  status          ClaimStatus @default(SUBMITTED)
  reviewNote      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedAmount  Float?
  paidAt          DateTime?

  images          ClaimImage[]
  shipment        Shipment    @relation(fields: [shipmentId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("claims")
}

model ClaimImage {
  id        String   @id @default(uuid())
  claimId   String
  url       String
  publicId  String

  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("claim_images")
}

// ─── PAYMENTS (Paystack) ──────────────────────────────────────────────────────

model Payment {
  id                String         @id @default(uuid())
  reference         String         @unique
  userId            String
  shipmentId        String?

  amountKobo        Int
  currency          String         @default("NGN")
  channel           PaymentChannel?
  status            PaymentStatus  @default(PENDING)

  paystackId        Int?
  gatewayResponse   String?
  paidAt            DateTime?
  authorizationCode String?
  cardLast4         String?
  cardBank          String?

  refundedAt        DateTime?
  refundReference   String?
  refundAmountKobo  Int?

  metadata          Json?

  user              User           @relation(fields: [userId], references: [id])
  shipment          Shipment?      @relation(fields: [shipmentId], references: [id])

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("payments")
}

// ─── SUPPORT (Sprint 6) ───────────────────────────────────────────────────────

model SupportTicket {
  id           String          @id @default(uuid())
  ticketNumber String          @unique // e.g. TKT-20260311-001
  customerId   String
  assignedToId String?
  category     TicketCategory  @default(OTHER)
  subject      String
  status       TicketStatus    @default(OPEN)
  priority     String          @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  shipmentId   String?         // linked shipment if relevant
  resolvedAt   DateTime?
  closedAt     DateTime?

  customer     User            @relation("TicketCustomer", fields: [customerId], references: [id])
  assignedTo   User?           @relation("TicketAgent", fields: [assignedToId], references: [id])
  messages     TicketMessage[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("support_tickets")
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  senderId  String
  body      String
  isInternal Boolean      @default(false) // internal agent notes not visible to customer
  attachmentUrl String?

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime      @default(now())

  @@map("ticket_messages")
}

// Sprint 6: Canned responses / template library
model CannedResponse {
  id        String    @id @default(uuid())
  title     String
  body      String
  category  String?
  isActive  Boolean   @default(true)
  createdBy String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("canned_responses")
}

// ─── KNOWLEDGE BASE / FAQ (Sprint 5) ─────────────────────────────────────────

model FaqItem {
  id        String      @id @default(uuid())
  question  String
  answer    String
  category  FaqCategory @default(OTHER)
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdBy String?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("faq_items")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ─── SYSTEM ──────────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?

  user       User?    @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())

  @@map("activity_logs")
}

model AppSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String?
  updatedBy String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("app_settings")
}
